{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env", "**/.env.*"],
  "tasks": {
    "build": {
      "outputs": ["dist/**", "*.tsbuildinfo"],
      "cache": true
    },
    "build:prod": {
      "outputs": ["dist/**", "*.tsbuildinfo"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
