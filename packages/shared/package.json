{
  "name": "shared",
  "version": "1.0.0",
  "description": "Shared services and utilities for Voice Agent",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prebuild": "mkdir -p dist || true"
  },
  "dependencies": {
    "@angular/common": "^17.3.12",
    "@angular/core": "^17.3.12",
    "rxjs": "^7.8.1",
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./services": {
      "import": "./dist/services/index.js",
      "require": "./dist/services/index.js",
      "types": "./dist/services/index.d.ts"
    }
  }
}
