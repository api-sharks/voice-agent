{
  "name": "voice-agent-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "npm --workspace=web run start",
    "dev": "npm --workspace=web run dev",
    "build": "npm --workspace=web run build",
    "dev:web": "npm --workspace=web run dev",
    "build:web": "npm --workspace=web run build",
    "build:shared": "npm --workspace=shared run build",
    "turbo:build": "turbo run build"
  },
  "devDependencies": {
    "turbo": "^2.9.18"
  }
}
